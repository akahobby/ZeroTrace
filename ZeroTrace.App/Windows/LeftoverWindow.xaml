<Window x:Class="ZeroTrace.App.Windows.LeftoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Leftover Items" Height="350" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource ZTWindowBackground}"
        BorderBrush="{StaticResource ZTBorderBrush}"
        Padding="10">
    <DockPanel Margin="0"
               Background="{StaticResource ZTWindowBackground}">
        <TextBlock DockPanel.Dock="Top"
                   Margin="0 0 0 8"
                   TextWrapping="Wrap"
                   Text="Select which leftover items you want ZeroTrace to remove. Items will be deleted permanently." />

        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 8 0 0">
            <Button Width="90"
                    Margin="0 0 8 0"
                    Content="Select All"
                    Click="OnSelectAllClick" />
            <Button Width="120"
                    Margin="0 0 8 0"
                    Content="Delete Selected"
                    IsDefault="True"
                    Click="OnRemoveSelectedClick" />
            <Button Width="80"
                    Content="Cancel"
                    IsCancel="True" />
        </StackPanel>

        <!-- Leftover items grid -->
        <DataGrid x:Name="LeftoversGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  Background="{StaticResource ZTControlBackground}"
                  Foreground="{StaticResource ZTForeground}"
                  BorderBrush="{StaticResource ZTBorderBrush}"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="{StaticResource ZTBorderBrush}"
                  VerticalGridLinesBrush="{StaticResource ZTBorderBrush}"
                  RowBackground="{StaticResource ZTControlBackground}"
                  AlternatingRowBackground="{StaticResource ZTControlAltBackground}"
                  HeadersVisibility="Column"
                  ItemsSource="{Binding Leftovers}">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{StaticResource ZTControlAltBackground}" />
                    <Setter Property="Foreground" Value="{StaticResource ZTForeground}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ZTBorderBrush}" />
                </Style>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{StaticResource ZTControlBackground}" />
                    <Setter Property="Foreground" Value="{StaticResource ZTForeground}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ZTBorderBrush}" />
                    <Setter Property="SnapsToDevicePixels" Value="True" />
                </Style>
                <Style TargetType="CheckBox">
                    <Setter Property="Foreground" Value="{StaticResource ZTForeground}" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="HorizontalAlignment" Value="Center" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="CheckBox">
                                <Grid>
                                    <Border x:Name="Box"
                                            Width="14"
                                            Height="14"
                                            Background="Transparent"
                                            BorderBrush="{StaticResource ZTForeground}"
                                            BorderThickness="1" />
                                    <Path x:Name="CheckMark"
                                          Data="M 2 7 L 5 10 L 12 2"
                                          Stroke="{StaticResource ZTForeground}"
                                          StrokeThickness="2"
                                          StrokeEndLineCap="Square"
                                          StrokeStartLineCap="Square"
                                          Visibility="Collapsed" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Remove" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Type"
                                    Binding="{Binding Type}"
                                    Width="100" />
                <DataGridTextColumn Header="Path"
                                    Binding="{Binding Path}"
                                    Width="*" />
                <DataGridTextColumn Header="Size"
                                    Binding="{Binding SizeBytes}"
                                    Width="120" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>

